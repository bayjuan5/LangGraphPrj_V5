# Python cache
__pycache__/
*.py[cod]
*.pyo

# Virtual environments
venv/
.venv/
env/

# Environment secrets
.env

# Logs / temp
*.log
.DS_Store
Thumbs.db

# Large model / data files — do NOT commit large SVS files
# The TCGA_test/ sample (~25 MB) IS committed intentionally.
# Add other large WSI paths here if needed:
# *.svs

# ROSIE model weights — 400 MB, must NOT be committed.
# Users must request these separately from Enable Medicine.
# See GET_ROSIE_WEIGHTS.md for instructions.
rosie_weights.pth
rosie/rosie_weights.pth
*.pth

# Generated outputs (run-time artefacts) — keep directory skeleton
outputs/*
!outputs/.gitkeep

# IDE
.idea/
.vscode/
